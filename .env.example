# Copy to .env and fill in values

# Vision model — llama3.2-vision:11b (best) or llava:7b (lighter, 8GB RAM)
VISION_MODEL=llama3.2-vision:11b

# Text model for final inference — llama3:latest is already installed
TEXT_MODEL=llama3:latest

# OpenWeatherMap free-tier key (60 req/min) — leave blank for offline mode
# Get one at: https://openweathermap.org/api
OPENWEATHER_KEY=

# Ollama URL — default is localhost; change if running on another machine
OLLAMA_URL=http://localhost:11434
