# Copy to .env and fill in values

# Text model for advisory generation
# Mac M1 (16GB):   llama3:latest  (8GB — best quality)
# Linux (12GB RAM): llama3.2:3b   (2.2GB — fast, fits comfortably)
TEXT_MODEL=llama3:latest

# Vision model — ONLY needed if models/pomegranate.onnx is missing (LLaVA fallback)
# Mac M1 (16GB):   llama3.2-vision:11b
# Linux (12GB RAM): llava:7b
VISION_MODEL=llama3.2-vision:11b

# Ollama URL — default is localhost; change if Ollama runs on another machine
OLLAMA_URL=http://localhost:11434

# Database path (relative to project root or absolute)
FARMING_DB=farming.db

# Upload directory for incoming photos
UPLOAD_DIR=uploads

# Trained ONNX models directory
MODELS_DIR=models

# Server port
PORT=5002
