[Unit]
Description=Farming crop advisor
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=REPO_DIR
EnvironmentFile=-REPO_DIR/.env
ExecStartPre=/bin/bash -c 'pgrep ollama || (ollama serve &>/tmp/ollama.log & sleep 3)'
ExecStart=REPO_DIR/venv/bin/uvicorn main:app --host 0.0.0.0 --port 5002 --workers 1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
